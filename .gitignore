# ============================================================================
# Dark Star Electronics — .gitignore
# ============================================================================
# NOTE: gitignore does NOT support inline comments. Keep comments on their
# own lines.

# ---------- Snowflake CLI / DCM ---------------------------------------------
# `snow dcm plan --save-output`
out/
# Older CLI versions write here
output/
# Local Cortex Code session/plan state (DO NOT publish)
.snowflake/
*.dcm.tmp
deployment_history*.json

# ---------- Secrets / credentials -------------------------------------------
# Never commit credentials or local connection profiles
keys/
.env
.env.*
!.env.example
*.pem
*.p8
*.key
*.crt
*.pfx
id_rsa*
*.token
secrets.toml
connections.toml
config.toml
credentials*.json
service-account*.json

# ---------- Python ----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
build/
dist/
.tox/
.nox/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.venv/
venv/
env/
.python-version

# ---------- Node / JS (future apps) -----------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------- dbt (future) ----------------------------------------------------
target/
dbt_packages/
dbt_modules/
logs/
.user.yml

# ---------- IDE / editors ---------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.history/

# ---------- OS junk ---------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------- Misc ------------------------------------------------------------
*.log
*.bak
*.backup
*.tmp
tmp/
temp/
